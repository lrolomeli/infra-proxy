# === SSL (DNS-01 — necesario en prod y staging) ===
# Token de Cloudflare con permisos Zone:DNS:Edit
# Sin IP pública igual funciona — Caddy obtiene wildcard certs vía API
CLOUDFLARE_API_TOKEN=

# === Staging (Cloudflare Tunnel) ===
# Token del tunnel creado en Cloudflare Zero Trust Dashboard
TUNNEL_TOKEN=
