# ── Routing ──────────────────────────────────────────────────────────────────
# Caddy usa tls internal (self-signed). Cloudflare Tunnel tiene noTLSVerify:true
# así que el SSL se maneja en el edge de Cloudflare, no en Caddy.
# ──────────────────────────────────────────────────────────────────────────────

*.midominio.com, midominio.com, www.midominio.com {
    tls internal

    # API va directo al backend (evita doble proxy vía nginx/frontend)
    handle_path /api/* {
        reverse_proxy midominio-backend:5000
    }

    # Términos y privacidad servidos por backend
    handle /privacy* {
        reverse_proxy midominio-backend:5000
    }
    handle /terms* {
        reverse_proxy midominio-backend:5000
    }

    # Todo lo demás → frontend (SPA, landing, assets)
    handle {
        reverse_proxy midominio-frontend:80
    }
}

