# ── Routing ──────────────────────────────────────────────────────────────────
# Caddy usa tls internal (self-signed). Cloudflare Tunnel tiene noTLSVerify:true
# así que el SSL se maneja en el edge de Cloudflare, no en Caddy.
# ──────────────────────────────────────────────────────────────────────────────

*.aytencargo.com.mx, aytencargo.com.mx, www.aytencargo.com.mx {
    tls internal
    reverse_proxy gs-frontend:80
}

*.cosmeticosplasa.com, cosmeticosplasa.com, www.cosmeticosplasa.com {
    tls internal
    reverse_proxy restauto-frontend:80
}

*.aytencargo.com, aytencargo.com, www.aytencargo.com,
*.aytencargo.mx, aytencargo.mx, www.aytencargo.mx {
    tls internal
    reverse_proxy aytc-frontend:80
}

