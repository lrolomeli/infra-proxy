# ── Routing ──────────────────────────────────────────────────────────────────
# Caddy maneja SSL automático. Con CLOUDFLARE_API_TOKEN obtiene wildcard certs.
# Sin token: certs self-signed (HTTP-01, sin wildcard).
# ──────────────────────────────────────────────────────────────────────────────

*.aytencargo.com.mx, aytencargo.com.mx, www.aytencargo.com.mx {
    reverse_proxy gs-frontend:80
}

*.cosmeticosplasa.com, cosmeticosplasa.com, www.cosmeticosplasa.com {
    reverse_proxy restauto-frontend:80
}

