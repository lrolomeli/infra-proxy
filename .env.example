# === SSL (DNS-01 — solo necesario en producción) ===
# Token de Cloudflare con permisos Zone:DNS:Edit
# Se usa en CADDY_MODE=prod para wildcard certs vía ACME DNS-01
CLOUDFLARE_API_TOKEN=

# === Modo de Caddy ===
# prod     → usa Caddyfile.prod + wildcard certs reales (DNS-01)
# staging  → usa Caddyfile.staging + tls internal (Cloudflare edge termina SSL)
CADDY_MODE=prod

# === Staging (Cloudflare Tunnel) ===
# Token del tunnel creado en Cloudflare Zero Trust Dashboard
# Solo se necesita si levantas con --profile staging
TUNNEL_TOKEN=
