# === Cloudflare API Token (solo producción) ===
# Permisos Zone:DNS:Edit — necesario para wildcard certs vía ACME DNS-01
# En staging no se necesita (Caddy usa tls internal, Cloudflare edge termina SSL)
CLOUDFLARE_API_TOKEN=

# === Staging (Cloudflare Tunnel) ===
# Si TUNNEL_TOKEN está definido, Caddy usa tls internal automáticamente.
# Sin TUNNEL_TOKEN → producción (certs reales vía DNS-01).
# Solo se necesita si levantas con --profile staging.
TUNNEL_TOKEN=

# === Apps (Caddyfile se genera automáticamente) ===
# Cada app necesita: DOMAIN, BACKEND_HOST, BACKEND_PORT, FRONTEND_HOST, FRONTEND_PORT
# Todas las variables son obligatorias por app.

APPS=4

# ── App 1 ──────────────────────────────────────────────────────────────────
APP_1_DOMAIN=aytencargoxfa.com
APP_1_BACKEND_HOST=gs-backend
APP_1_BACKEND_PORT=5000
APP_1_FRONTEND_HOST=gs-frontend
APP_1_FRONTEND_PORT=80

# ── App 2 ──────────────────────────────────────────────────────────────────
APP_2_DOMAIN=dominio2.com
APP_2_BACKEND_HOST=gs-backend
APP_2_BACKEND_PORT=5000
APP_2_FRONTEND_HOST=gs-frontend
APP_2_FRONTEND_PORT=80

# ── App 3 ──────────────────────────────────────────────────────────────────
APP_3_DOMAIN=dominio3.com
APP_3_BACKEND_HOST=gs-backend
APP_3_BACKEND_PORT=5000
APP_3_FRONTEND_HOST=gs-frontend
APP_3_FRONTEND_PORT=80

# ── App 4 ──────────────────────────────────────────────────────────────────
APP_4_DOMAIN=dominio4.com
APP_4_BACKEND_HOST=gs-backend
APP_4_BACKEND_PORT=5000
APP_4_FRONTEND_HOST=gs-frontend
APP_4_FRONTEND_PORT=80
